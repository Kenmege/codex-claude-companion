{
  "name": "codex-plugin-cc",
  "version": "1.1.1",
  "type": "module",
  "description": "Codex-supervised Claude coding workspace plus isolated agentic review, adversarial review, deep review, and security review lanes.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kenmege/codex-plugin-cc.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "bin": {
    "codex-claude-review": "scripts/claude-review-companion.mjs",
    "codex-claude": "scripts/claude-review-companion.mjs"
  },
  "files": [
    ".agents/",
    ".codex-plugin/",
    "commands/",
    "schemas/",
    "skills/",
    "scripts/claude-review-companion.mjs",
    "scripts/validate-repo.mjs",
    "scripts/bin/",
    "scripts/lib/",
    "README.md",
    "CHANGELOG.md",
    "SECURITY.md",
    "CONTRIBUTING.md",
    "LICENSE",
    "NOTICE",
    "docs/architecture.md"
  ],
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "lint": "node scripts/validate-repo.mjs",
    "test": "node --test",
    "test:windows": "node --test test/args.test.mjs test/mcp-config.test.mjs test/release-docs.test.mjs test/render.test.mjs",
    "check": "npm run lint && npm test",
    "pack:check": "npm pack --dry-run"
  },
  "keywords": [
    "codex",
    "plugin",
    "claude",
    "claude-code",
    "coding-agent",
    "orchestration",
    "review",
    "opus",
    "sonnet",
    "agentic",
    "adversarial-review",
    "deep-review",
    "security-review"
  ]
}
